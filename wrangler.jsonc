{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jeffreypotts",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jeffreypotts-newsletter",
      "database_id": "339b4808-2fcf-4d9a-b69b-ee5a66b758f5"
    }
  ]
}
